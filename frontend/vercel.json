{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://nutcase-anyway-unsterile.ngrok-free.dev/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "ngrok-skip-browser-warning",
          "value": "true"
        }
      ]
    }
  ]
}
